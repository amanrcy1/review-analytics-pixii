# Google Gemini API Key (FREE — primary AI provider)
# Get yours: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (PAID — optional fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Groq (FREE — fast fallback if Gemini hits rate limits)
# Get yours: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# RapidAPI (for real Amazon product data)
# Get yours: https://rapidapi.com — subscribe to Real-Time Amazon Data
RAPIDAPI_KEY=your_rapidapi_key_here

# ─── Scaling Configuration ───────────────────────────────────
# Adjust based on your RapidAPI tier:
#
#   Free  (100 calls/mo):  MAX_COMPETITORS=9,  REVIEW_PAGES=1  → ~90 reviews,  ~11 queries/mo
#   Basic (1000 calls/mo): MAX_COMPETITORS=9, REVIEW_PAGES=10 → ~900 reviews, ~10 queries/mo
#
MAX_COMPETITORS=9
REVIEW_PAGES_PER_PRODUCT=1
